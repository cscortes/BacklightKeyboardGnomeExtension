<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.kbd-backlight-scheduler"
          path="/org/gnome/shell/extensions/kbd-backlight-scheduler/">

    <key name="mode" type="s">
      <default>'scheduled'</default>
      <summary>Backlight control mode</summary>
      <description>One of: always-on, always-off, scheduled</description>
    </key>

    <key name="brightness" type="i">
      <default>3</default>
      <range min="0" max="3"/>
      <summary>Brightness level for always-on mode (0-3)</summary>
    </key>

    <key name="always-on-aura-mode" type="s">
      <default>'Static'</default>
      <summary>Aura effect for always-on mode</summary>
      <description>One of: Static, Breathe, Strobe, Rainbow</description>
    </key>

    <key name="always-on-aura-color" type="s">
      <default>'#ffffff'</default>
      <summary>Aura colour for always-on mode (hex)</summary>
    </key>

    <key name="schedules" type="s">
      <default>'[]'</default>
      <summary>JSON array of schedule entries</summary>
      <description>Array of {start_h, start_m, end_h, end_m, brightness} objects serialized as JSON</description>
    </key>

    <key name="max-brightness" type="i">
      <default>3</default>
      <range min="1" max="255"/>
      <summary>Maximum brightness level read from hardware</summary>
    </key>

    <key name="asus-kbd-detected" type="b">
      <default>false</default>
      <summary>Whether ASUS WMI keyboard LED (asus::kbd_backlight) was detected</summary>
    </key>

    <key name="aura-available" type="b">
      <default>false</default>
      <summary>Whether Aura RGB control (asusctl) is available — separate from white backlight levels</summary>
    </key>

  </schema>
</schemalist>
